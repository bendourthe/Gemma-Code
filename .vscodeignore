# Source and test files — not needed at runtime
src/**
tests/**
configs/**
scripts/**
docs/**
examples/**
lib/**
assets/**
!assets/icon.png
!assets/icon.svg
!assets/sidebar-icon.svg
!assets/vector.svg
coverage/**

# Build artifacts that are not extension output
out/test/**
out/**/*.map

# Tooling and CI configuration
.vscode/**
.vscode-test/**
.claude/**
.github/**
.gitignore
.gitattributes
.npmrc
.eslintignore
eslint.config.mjs
tsconfig.json
CHANGELOG.md
README.md
CLAUDE.md

# Trim unnecessary files from bundled node_modules
# (vsce automatically excludes devDependencies when --no-dependencies is not used)
node_modules/**/*.md
node_modules/**/*.map
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/.npmignore
node_modules/**/.travis.yml
node_modules/**/CHANGELOG*
node_modules/**/LICENSE*
node_modules/**/HISTORY*
# better-sqlite3: exclude C++ source (only .node binary + JS lib needed)
node_modules/better-sqlite3/src/**
node_modules/better-sqlite3/deps/**
node_modules/better-sqlite3/binding.gyp
node_modules/better-sqlite3/build/Release/.forge-meta
# prebuild-install not needed at runtime
node_modules/prebuild-install/**

# Python and Rust artifacts
**/__pycache__/**
**/*.pyc
**/*.pyo
target/**

# TypeScript source maps and declaration files (already excluded via pattern below)
**/*.ts
!out/**/*.js
