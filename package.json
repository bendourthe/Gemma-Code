{
  "name": "gemma-code",
  "displayName": "Gemma Code",
  "description": "Local agentic coding assistant powered by Gemma 4 via Ollama",
  "version": "0.1.0",
  "publisher": "gemma-code",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gemma-code-sidebar",
          "title": "Gemma Code",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "gemma-code-sidebar": [
        {
          "id": "gemma-code.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "gemma-code.ping",
        "title": "Gemma Code: Ping Ollama"
      }
    ],
    "configuration": {
      "title": "Gemma Code",
      "properties": {
        "gemma-code.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "gemma-code.modelName": {
          "type": "string",
          "default": "gemma3:27b",
          "description": "Model to use for inference"
        },
        "gemma-code.maxTokens": {
          "type": "number",
          "default": 8192,
          "description": "Maximum context tokens"
        },
        "gemma-code.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Sampling temperature"
        },
        "gemma-code.requestTimeout": {
          "type": "number",
          "default": 60000,
          "description": "HTTP timeout in milliseconds"
        },
        "gemma-code.toolConfirmationMode": {
          "type": "string",
          "enum": [
            "always",
            "ask",
            "never"
          ],
          "default": "ask",
          "description": "When to prompt for confirmation before running terminal commands or editing files. 'always': always ask. 'ask': ask for destructive operations only. 'never': run without confirmation (use with caution)."
        },
        "gemma-code.maxAgentIterations": {
          "type": "number",
          "default": 20,
          "description": "Maximum number of agentic tool-use iterations per user message before the loop terminates."
        },
        "gemma-code.editMode": {
          "type": "string",
          "enum": [
            "auto",
            "ask",
            "manual"
          ],
          "enumDescriptions": [
            "Apply file edits immediately without prompting.",
            "Show a diff and ask for confirmation before applying any file edit.",
            "Show diffs in the chat panel but never write files (review-only mode)."
          ],
          "default": "auto",
          "description": "Controls how file edits (edit_file, write_file, create_file) are applied. 'auto': apply immediately. 'ask': show diff and confirm. 'manual': show diff only, never write."
        },
        "gemma-code.useBackend": {
          "type": "boolean",
          "default": true,
          "description": "When true, Gemma Code starts a local Python FastAPI backend that handles prompt formatting and context management. When false, the extension talks directly to Ollama."
        },
        "gemma-code.backendPort": {
          "type": "number",
          "default": 11435,
          "description": "Port for the local Python inference backend. Change this if 11435 conflicts with another service."
        },
        "gemma-code.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python executable used to start the backend (e.g. 'python3' or an absolute path to a virtual-environment interpreter)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "vitest run --config configs/vitest.config.ts",
    "test:integration": "vitest run --config configs/vitest.config.ts --reporter=verbose tests/integration",
    "lint": "eslint src",
    "package": "vsce package",
    "bench": "vitest bench --config configs/vitest.config.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^5.2.3",
    "@types/marked": "^4.3.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vscode/vsce": "^2.24.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "diff": "^5.2.2",
    "highlight.js": "^11.11.1",
    "marked": "^4.3.0",
    "node-html-parser": "^6.1.13"
  }
}
